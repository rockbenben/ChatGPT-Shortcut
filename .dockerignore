# Dependencies
node_modules/

# Build output
build/
.docusaurus/

# Version control
# 不要忽略 .git/：showLastUpdateTime 需要 git 历史读取文档最后更新时间
# （.git 只进 builder 阶段，多阶段构建后不会带进最终 nginx 镜像）
.gitignore

# IDE and editor
.idea/
.vscode/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Docker files (not needed inside container)
Dockerfile
docker-compose.yml
.dockerignore

# Documentation and misc
README.md
LICENSE
*.md
!docs/**/*.md

# Test files
*.test.js
*.spec.js
__tests__/
coverage/
